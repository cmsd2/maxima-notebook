{
    "comments": {
        "blockComment": [ "/*", "*/" ]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "wordPattern": "[a-zA-Z_%?][a-zA-Z0-9_%?]*",
    "indentationRules": {
        "increaseIndentPattern": "(\\b(block|if|then|else|elseif|for|while|do|lambda)\\b.*[,(]\\s*$)|(\\(\\s*$)",
        "decreaseIndentPattern": "^\\s*\\)\\s*[;$]?\\s*$"
    },
    "onEnterRules": [
        {
            "beforeText": { "pattern": "^\\s*/\\*" },
            "afterText": { "pattern": "^\\s*\\*/" },
            "action": {
                "indent": "indentOutdent",
                "appendText": " * "
            }
        },
        {
            "beforeText": { "pattern": "^\\s*/\\*.*(?!\\*/)\\s*$" },
            "action": {
                "indent": "none",
                "appendText": " * "
            }
        },
        {
            "beforeText": { "pattern": "^\\s*\\*\\s" },
            "action": {
                "indent": "none",
                "appendText": "* "
            }
        }
    ]
}
