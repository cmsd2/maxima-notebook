{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Maxima",
	"patterns": [
		{
			"include": "#comment"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#lisp-escape"
		},
		{
			"include": "#function-definition"
		},
		{
			"include": "#definition-operators"
		},
		{
			"include": "#terminators"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#constant"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#variables"
		}
	],
	"repository": {
		"comment": {
			"patterns": [
				{
					"name": "comment.block.maxima",
					"begin": "/\\*",
					"beginCaptures": {
						"0": {"name": "comment.block.begin.maxima"}
					},
					"end": "\\*/",
					"endCaptures": {
						"0": {"name": "comment.block.end.maxima"}
					},
					"patterns": [
						{"include": "#comment"}
					]
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.maxima",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.maxima",
					"match": "\\\\."
				}
			]
		},
		"lisp-escape": {
			"begin": "^\\s*(:lisp)\\b",
			"beginCaptures": {
				"1": { "name": "keyword.control.lisp-escape.maxima" }
			},
			"end": "$",
			"name": "meta.embedded.lisp.maxima"
		},
		"function-definition": {
			"match": "\\b([a-zA-Z_%?][a-zA-Z0-9_%?]*)\\s*\\([^)]*\\)\\s*(::?=)",
			"captures": {
				"1": { "name": "entity.name.function.definition.maxima" },
				"2": { "name": "keyword.operator.definition.maxima" }
			}
		},
		"definition-operators": {
			"patterns": [
				{
					"name": "keyword.operator.definition.maxima",
					"match": "::?="
				},
				{
					"name": "keyword.operator.assignment.maxima",
					"match": "::?"
				}
			]
		},
		"terminators": {
			"patterns": [
				{
					"name": "punctuation.terminator.display.maxima",
					"match": ";"
				},
				{
					"name": "punctuation.terminator.suppress.maxima",
					"match": "\\$"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.maxima",
					"match": "\\b(do|while|unless|for|from|thru|step|next|in|if|then|else|elseif|return|go|block|lambda|catch|throw|error|errcatch)\\b"
				},
				{
					"name": "keyword.function.maxima",
					"match": "\\b(define)\\b"
				},
				{
					"name": "keyword.operator.maxima",
					"match": "\\b(and|or|not)\\b"
				},
				{
					"name": "keyword.module.maxima",
					"match": "\\b(load)\\b"
				}
			]
		},
		"constant": {
			"patterns": [
				{
					"name": "constant.numeric.maxima",
					"match": "\\b([+-]?\\d+(\\.\\d*)?|\\.\\d+)([BbDdEeSs][+-]?\\d+)?\\b"
				},
				{
					"name": "constant.language.maxima",
					"match": "\\b(%e|%gamma|%i|%phi|%pi|true|false|inf|infinity|minf|ind|und|zeroa|zerob)\\b"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.call.maxima",
					"match": "\\b[a-zA-Z_%?][a-zA-Z0-9_%?]*(?=\\s*\\()"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.maxima",
					"match": "\\b([a-zA-Z_%?][a-zA-Z0-9_%?]*|%%?|%[io]\\d+|__)\\b"
				}
			]
		}
	},
	"scopeName": "source.maxima"
}
